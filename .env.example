# =============================================================================
# AI 辅助代码评审与质量门禁平台 — 环境变量样例
# Task:        B0-A.11
# Requirement: R24.6
# Design:      design.md §17.2
#
# 用法：
#   cp .env.example .env
#   docker compose up -d
#
# 注意：
#   - .env 已被 .gitignore 忽略；只有 .env.example 会被提交。
#   - 生产环境必须替换 TOKEN_ENCRYPTION_KEY / JWT_SECRET / DB_PASSWORD。
# =============================================================================

# ----------- 数据库（PostgreSQL）-----------
DB_USER=acrqg
DB_PASSWORD=replace-me-in-prod

# ----------- AI 服务（M06）-----------
# 留空时 Worker 在 AI_REVIEWING 阶段直接走降级路径（design.md §6.6 / R12.5）
AI_REVIEW_BASE_URL=
AI_REVIEW_TIMEOUT_SECONDS=60

# ----------- Worker 配置（M03）-----------
# 单 worker JVM 内消费线程数；合法区间 [1, 32]（design.md §17.2 / R21.4 / R24.3）
REVIEW_WORKER_CONCURRENCY=4

# ----------- Webhook（M03）-----------
WEBHOOK_SIGNATURE_HEADER=X-Hub-Signature-256

# ----------- 安全（生产必须替换）-----------
# AES-GCM 派生密钥；建议 ≥ 32 字节随机串（R5.3 / R21.1 / R23.2）
TOKEN_ENCRYPTION_KEY=dev-change-me-32-bytes-token-encryption-key!!
# JWT HS256 共享密钥；建议 ≥ 32 字节随机串（R1.4 / R23.1）
JWT_SECRET=please-change-me-32-bytes-minimum-secret-key-for-jwt-hmac-signing
JWT_ACCESS_TTL_SECONDS=7200
JWT_REFRESH_TTL_SECONDS=604800
